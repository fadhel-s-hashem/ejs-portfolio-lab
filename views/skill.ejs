<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>skills</title>
</head>
<%- include('./partials/nav') %>

    <body>

        <ul>
            <% skills.forEach(function(item){ %>

                <li>
                    <h1><%= item.name %></h1>       
                    
                    <p>
                        <%= item.category %>
                    </p>
                    <p>
                        <%= item.level %>
                    </p>
                    <p>
                        <%= item.description %>
                    </p>
                   
                </li>

                <%})%>
        </ul>

    </body>

</html>